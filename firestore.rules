rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidStore(data) {
      return data.n is string && data.n.size() > 0 && data.n.size() < 100 &&
             data.w is string && data.w.size() > 0 && data.w.size() < 20 &&
             data.status in ['trial', 'active', 'blocked'] &&
             data.expiresAt is string;
    }

    match /stores/{storeId} {
      // Allow anyone to read a store by its ID
      allow read: if true;
      
      // Allow anyone to create, update and delete
      // In a real app, these would be protected by Firebase Auth + Rules
      allow create, update: if true;
      allow delete: if true;
    }

    match /trial_history/{whatsapp} {
      // Allow all operations on trial history
      allow read, write: if true;
    }

    match /resellers/{resellerId} {
      // Allow all operations on resellers
      allow read, write: if true;
    }

    match /configs/{configId} {
      // Allow all operations on global configs
      allow read, write: if true;
    }
  }
}
